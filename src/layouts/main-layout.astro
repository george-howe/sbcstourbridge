---
import Navbar from '../components/navbar.tsx'
import Footer from '../components/footer.tsx'

export interface LayoutProps {
  title: string
  description?: string
}

const { title, description = 'Silent Book Club Stourbridge — a book club for introverts. Join us for silent reading in Stourbridge and online.' } = Astro.props as LayoutProps
---


<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="title" content={title} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Mulish:ital,wght@0,200..1000;1,200..1000&family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="font-mulish text-text-gray">
    <a
      href="#main-content"
      class="sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-white focus:text-primary-slate focus:px-4 focus:py-2 focus:rounded focus:outline focus:outline-2 focus:outline-primary-slate focus:[clip:auto] focus:[height:auto] focus:[width:auto] focus:[margin:0] focus:overflow-visible focus:whitespace-normal"
    >
      Skip to main content
    </a>
    <Navbar client:load />
    <main id="main-content" class="bg-no-repeat bg-cover bg-center pt-20">
      <slot />
      <Footer />
    </main>
  </body>
</html>
