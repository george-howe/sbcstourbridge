---
import MainLayout from '../layouts/main-layout.astro'
---

<MainLayout
  title="Giveaway Terms and Conditions | Silent Book Club Stourbridge"
  description="Terms and conditions for the Silent Book Club Stourbridge giveaway of Godless Cosmologies by Christy Theodoulou."
>

  <section
    class="w-full bg-primary-slate h-[35vh] lg:h-[50vh] flex justify-center items-end"
    aria-labelledby="page-title"
  >
    <div class="py-[30px] lg:py-[41px] px-6 sm:px-12 lg:px-16 flex flex-col justify-center items-center bg-white gap-2.5">
      <h1 id="page-title" class="text-[30px] leading-[1.25] lg:text-[50px] lg:leading-[1.24] font-dm capitalize text-primary-slate text-center">
        Silent Book Club Stourbridge Giveaway (<cite class="not-italic">Godless Cosmologies</cite>)
      </h1>
    </div>
  </section>

  <section
    class="w-full page-section-y page-section-x mx-auto bg-white"
    aria-labelledby="giveaway-terms-title"
  >
    <div class="page-container w-full max-w-[65ch] lg:max-w-[900px]">
      <h2
        id="giveaway-terms-title"
        class="text-[30px] font-nunito tracking-wide capitalize leading-[1.25] md:text-[40px] text-primary-slate font-bold mb-8"
      >
        Giveaway Terms and Conditions
      </h2>

      <ol class="list-decimal pl-6 flex flex-col gap-6 text-base md:text-[18px] font-mulish text-text-gray leading-[1.5]">
        <li>
          <strong class="text-primary-slate">Promoter</strong><br />
          This giveaway is run by Silent Book Club Stourbridge via Instagram.
          This promotion is not affiliated with, sponsored by, or endorsed by Instagram.
        </li>
        <li>
          <strong class="text-primary-slate">Prize</strong><br />
          One winner will receive one signed advance reading copy of
          <cite>Godless Cosmologies</cite> by Christy Theodoulou.
        </li>
        <li>
          <strong class="text-primary-slate">Entry requirements</strong><br />
          To enter, participants must:
          <ul class="list-disc pl-6 mt-2 flex flex-col gap-1">
            <li>Follow <strong>@sbcstourbridge</strong> and <strong>@christytheodoulou</strong> on Instagram</li>
            <li>Like the giveaway post</li>
            <li>Comment on the giveaway post with the book they are currently reading</li>
          </ul>
        </li>
        <li>
          <strong class="text-primary-slate">Eligibility</strong>
          <ul class="list-disc pl-6 mt-2 flex flex-col gap-1">
            <li>Open to UK residents only</li>
            <li>Entrants must be aged 18 or over</li>
            <li>No purchase necessary</li>
          </ul>
        </li>
        <li>
          <strong class="text-primary-slate">Giveaway period</strong><br />
          Entries open on Monday 2 March 2026 and close at 11:59pm on Friday 6 March 2026.
          The winner will be announced on Saturday 7 March 2026.
        </li>
        <li>
          <strong class="text-primary-slate">Winner selection</strong><br />
          The winner will be chosen at random from all valid entries and contacted via Instagram.
          If the winner does not respond within 72 hours, another winner may be selected.
        </li>
        <li>
          <strong class="text-primary-slate">Delivery of prize</strong><br />
          The winner's postal address will be shared securely with the author for the sole purpose
          of sending the prize. The prize will be posted directly by the author.
          No alternative prize or cash equivalent is available.
        </li>
        <li>
          <strong class="text-primary-slate">Data protection</strong><br />
          Personal information provided will be used only for administering this giveaway
          and will not be stored or used for marketing purposes.
        </li>
        <li>
          <strong class="text-primary-slate">General</strong><br />
          Silent Book Club Stourbridge reserves the right to amend or withdraw the giveaway
          if necessary due to unforeseen circumstances.
        </li>
      </ol>
    </div>
  </section>
</MainLayout>
