---
import MainLayout from "../layouts/main-layout.astro"
import Button from "../components/button.tsx"
import {
	summaries,
	nextEvent,
	nextEventRSVPLink,
	upcomingEvents,
} from "../data/events"
---

<MainLayout
	title="Silent Book Club Stourbridge"
	description="Silent Book Club Stourbridge — a book club for introverts. Join us for silent reading events in Stourbridge and online."
>
	<section
		class="w-full bg-hero bg-no-repeat bg-cover h-screen lg:min-h-[110vh] page-section-x flex items-center"
		aria-labelledby="home-title"
	>
		<div class="page-container w-full flex flex-col">
			<h1
				id="home-title"
				class="text-[40px] leading-[1.25] md:text-[60px] xl:text-[85px] pb-0 font-dm xl:leading-[1.25] w-full xl:max-w-[50%] text-white ml-auto bg-primary-slate p-6"
			>
				Silent Book Club Stourbridge
			</h1>
			<p
				class="text-base md:text-[22px] pb-5 font-nunito font-bold text-secondary-brick w-full lg:max-w-[50%] ml-auto bg-primary-slate p-6 leading-[1.5]"
			>
				A book club for introverts.
			</p>
		</div>
	</section>

	<section class="bg-primary-slate" aria-labelledby="highlights-heading">
		<h2 id="highlights-heading" class="sr-only">What we offer</h2>
		<div
			class="page-container flex flex-col gap-8 lg:gap-10 lg:flex-row page-section-y page-section-x w-full justify-between"
		>
			{
				summaries.map(summary => {
					return (
						<div key={summary.title} class="w-full max-w-[358px] mx-auto flex flex-col justify-center items-center gap-3 md:gap-5">
							<h3 class="text-white font-nunito font-bold text-[22px] md:text-[25px] leading-[1.5] text-center">
								{summary.title}
							</h3>
							<p class="text-white md:text-[22px] tracking-tight font-mulish leading-[1.5] text-center">
								{summary.text}
							</p>
						</div>
					)
				})
			}
		</div>
	</section>

	<section
		class="w-full page-section-y page-section-x"
		aria-labelledby="next-event-heading"
	>
		<div class="page-container flex flex-col-reverse justify-center items-center lg:grid lg:grid-cols-2 gap-10">
			<div class="flex flex-col gap-8 max-w-[472px] items-center lg:items-start py-6">
				<h2
					id="next-event-heading"
					class="text-[30px] text-center capitalize lg:text-left font-nunito font-bold tracking-wide leading-[1.25] md:text-[50px] text-text-blue"
				>
					Join us at our next event...
				</h2>
				<p class="text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish text-text-gray leading-[1.5]">
					{nextEvent.summary}
				</p>
				<p class="text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish text-text-gray leading-[1.5]">
					{nextEvent.dateTime}
				</p>
				<Button text="RSVP Now" rsvpLink={nextEventRSVPLink} />
			</div>
			<div>
				<img src={nextEvent.img} alt={nextEvent.alt} class="w-full rounded-[12px]" />
			</div>
		</div>
	</section>

	<section class="bg-primary-slate" aria-labelledby="future-events-heading">
		<div class="page-container page-section-y page-section-x w-full">
			<h2
				id="future-events-heading"
				class="font-nunito font-bold tracking-wide text-center leading-[1.25] text-[30px] lg:text-[50px] w-full lg:max-w-[50%] pb-2 mx-auto text-white"
			>
				...And Our Future Events
			</h2>
			<p class="md:text-[22px] text-center tracking-tight font-mulish leading-[1.5] lg:max-w-[60%] mx-auto text-white">
				Here's what we've got lined up.
			</p>
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-x-[104px] lg:gap-y-[56px] mt-12 lg:mt-[93px]">
				{
					upcomingEvents.map(event => {
						return (
							<article key={`${event.location}-${event.date}`} class="w-full flex flex-col gap-4 bg-white p-8 rounded-[18px]">
								<img src={event.img} alt={event.alt} class="lg:h-80 w-full object-cover rounded-[12px]" />
								<div class="flex flex-col tracking-tight leading-[1.5]">
									<h3 class="text-primary-slate text-lg lg:text-[25px] font-nunito font-bold">
										{event.location}
									</h3>
									<p class="text-text-gray text-base lg:text-lg font-mulish">
										{event.date}
									</p>
								</div>
								{event.announced ? (
									<Button text="RSVP Now" rsvpLink={event.link} />
								) : null}
							</article>
						)
					})
				}
			</div>
		</div>
	</section>

	<section
		class="w-full page-section-y page-section-x bg-white"
		aria-labelledby="at-home-heading"
	>
		<div class="page-container flex flex-col-reverse justify-center items-center lg:grid lg:grid-cols-2 gap-10">
			<div class="flex flex-col gap-8 max-w-[472px] items-center lg:items-start py-6">
				<h2
					id="at-home-heading"
					class="text-[30px] text-center capitalize lg:text-left font-nunito font-bold tracking-wide leading-[1.25] md:text-[50px] text-text-blue"
				>
					Can't make our in-person meets?
				</h2>
				<p class="text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish text-text-gray leading-[1.5]">
					Join us every Wednesday evening on our WhatsApp group for our
					SBC: At Home Edition, 6.30-8.30pm
				</p>
				<Button
					text="Join us!"
					rsvpLink="https://chat.whatsapp.com/HR2Jaqi00d607ccUl0K6Vk"
				/>
			</div>
			<div>
				<img
					src="/athome.jpg"
					alt="Woman in a red jumper reading on a sofa"
					class="w-full rounded-[12px]"
				/>
			</div>
		</div>
	</section>

	<section class="bg-primary-slate" aria-labelledby="nyor-heading">
		<div class="page-container page-section-y page-section-x flex flex-col-reverse justify-center items-center lg:grid lg:grid-cols-2 gap-10">
			<div class="flex flex-col gap-8 max-w-[472px] items-center lg:items-start py-6">
				<h2
					id="nyor-heading"
					class="text-white text-[30px] text-center capitalize lg:text-left font-nunito font-bold tracking-wide leading-[1.25] md:text-[50px]"
				>
					National Year of Reading 2026
				</h2>
				<p class="text-white text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish leading-[1.5]">
					Proud to be a Partner Organisation for the National Year of Reading 2026 Go All In Campaign.
				</p>
				<Button text="More Info" rsvpLink="https://goallin.org.uk/" />
			</div>
			<div>
				<img src="/nyor.jpg" alt="Go All In Campaign logo" class="w-full rounded-[12px]" />
			</div>
		</div>
	</section>
</MainLayout>
