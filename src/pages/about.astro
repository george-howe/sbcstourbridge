---
import MainLayout from '../layouts/main-layout.astro'
import QuoteText from '../components/quote.tsx'
---

<MainLayout
  title="About Us | Silent Book Club Stourbridge"
  description="Learn about Silent Book Club Stourbridge — who we are, where we meet, and what to expect at our introvert-friendly reading events."
>

  <section
    class="w-full bg-primary-slate h-[35vh] lg:h-[50vh] flex justify-center items-end"
    aria-labelledby="page-title"
  >
    <div class="py-[30px] lg:py-[41px] px-6 sm:px-12 lg:px-16 flex flex-col justify-center items-center bg-white gap-2.5">
      <h1 id="page-title" class="text-[30px] leading-[1.25] lg:text-[50px] lg:leading-[1.24] font-dm capitalize text-primary-slate text-center">
        About Us
      </h1>
      <p class="text-base lg:text-[22px] leading-[1.5] tracking-tight font-jost text-text-gray">SBC Stourbridge</p>
    </div>
  </section>

  <section class="w-full page-section-y page-section-x flex items-center justify-center" aria-label="Quote">
    <QuoteText
      text="I declare after all there is no enjoyment like reading! How much sooner one tires of any thing than of a book!"
      name="Pride and Prejudice, Jane Austen"
    />
  </section>

  <section
    class="w-full page-section-y page-section-x mx-auto bg-primary-slate"
    aria-labelledby="who-we-are-heading"
  >
    <div class="page-container w-full flex flex-col-reverse lg:flex-row justify-between gap-10 items-center">
      <div class="flex flex-col gap-6 max-w-[65ch] lg:max-w-none">
        <h2
          id="who-we-are-heading"
          class="text-[30px] text-center lg:text-left font-nunito tracking-wide capitalize leading-[1.25] md:text-[50px] text-white font-bold"
        >
          Who we are
        </h2>
        <p class="text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish text-white leading-[1.5]">
          Are you a book lover looking for a quiet and cozy space to read alongside like-minded individuals? Join us every month as we gather to indulge in the joy of reading. There's no pressure to discuss the books we choose and no assigned reading – just comfortable silence and the pleasure of immersing ourselves in a great story. Whether you prefer fiction, non-fiction, or poetry, this is the perfect place to discover new literature and make connections with fellow book enthusiasts. Grab your favourite book and get ready for an evening of delightful reading!
        </p>
      </div>
      <img src="/bookClub.jpg" alt="A group of people reading together at a table" class="lg:h-80 w-full max-w-md object-cover rounded-[12px]" />
    </div>
  </section>

  <section
    class="w-full page-section-y page-section-x mx-auto bg-white"
    aria-labelledby="where-we-meet-heading"
  >
    <div class="page-container w-full flex flex-col-reverse lg:flex-row-reverse justify-between gap-10 items-center">
      <div class="flex flex-col gap-6 max-w-[65ch] lg:max-w-none">
        <h2
          id="where-we-meet-heading"
          class="text-[30px] text-center lg:text-left font-nunito tracking-wide capitalize leading-[1.25] md:text-[50px] text-primary-slate font-bold"
        >
          Where we meet
        </h2>
        <p class="text-base md:text-[22px] text-center lg:text-left tracking-tight font-mulish text-text-gray leading-[1.5]">
          We meet 3 times a month, trying to support as many local independent businesses in Stourbridge - or nearby - as we can. Sometimes this isn't always possible, so we try to strike a balance by also supporting businesses which support the local area. You'll find us in a variety of places, with at least one event outdoors during the summer (weather dependent of course!)
        </p>
      </div>
      <img src="/bookStack.jpg" alt="A stack of books" class="lg:h-80 w-full max-w-md object-cover rounded-[12px]" />
    </div>
  </section>
</MainLayout>
