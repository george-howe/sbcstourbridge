---
import MainLayout from '../layouts/main-layout.astro'
import ContactInfo from '../components/contact-box.tsx'
import ContactForm from '../components/contact-form.tsx'
---

<MainLayout
  title="Contact Us | Silent Book Club Stourbridge"
  description="Get in touch with Silent Book Club Stourbridge. We'd love to hear from you."
>

  <section
    class="w-full bg-contact bg-cover bg-center h-[50vh] flex justify-center items-end"
    aria-labelledby="page-title"
  >
    <div class="py-[30px] lg:py-[41px] px-6 sm:px-12 lg:px-16 flex flex-col justify-center items-center bg-white rounded-tl-[37px] rounded-tr-[37px] gap-2.5">
      <h1 id="page-title" class="text-[30px] leading-[1.25] lg:text-[50px] lg:leading-[1.24] font-dm capitalize text-primary-slate text-center">
        Contact Us
      </h1>
      <p class="text-base lg:text-[22px] leading-[1.5] tracking-tight font-jost text-text-gray">
        <a href="/" class="text-primary-slate underline underline-offset-2 hover:text-text-blue focus-ring rounded-sm">Home</a>
        <span aria-hidden="true"> / </span>
        <span class="text-text-gray">Contact</span>
      </p>
    </div>
  </section>

  <section
    class="page-container page-section-x w-full flex flex-col gap-8 lg:gap-10 pt-[100px] lg:pt-[160px] pb-[50px] lg:pb-[100px]"
    aria-labelledby="contact-intro-heading"
  >
    <h2
      id="contact-intro-heading"
      class="text-[30px] text-center capitalize font-dm tracking-wide leading-[1.25] md:text-[50px] mx-auto text-text-blue max-w-[65ch]"
    >
      We love meeting new people and helping them.
    </h2>

    <div class="grid grid-cols-1 gap-[55px] pt-12 lg:grid-cols-3 place-content-center">
      <ContactInfo />
      <ContactForm />
    </div>
  </section>
</MainLayout>
